<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:fitsSystemWindows="true">

    <!-- Fragment area -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Mini player (Spotify-style, shown when a song is active) -->
    <LinearLayout
        android:id="@+id/miniPlayerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Thin top border -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"/>

        <LinearLayout
            android:id="@+id/miniPlayer"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:background="#181818"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <!-- Album art mini -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="12dp">

                <ImageView
                    android:id="@+id/miniArt"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleType="centerCrop"
                    android:background="@color/elevated"
                    android:visibility="invisible"/>

                <TextView
                    android:id="@+id/miniArtLetter"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/subtext"
                    android:background="@color/elevated"
                    android:text="♪"/>
            </FrameLayout>

            <!-- Title + artist -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/miniTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text=""/>

                <TextView
                    android:id="@+id/miniArtist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/subtext"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp"
                    android:text=""/>
            </LinearLayout>

            <!-- Play/Pause button green circle -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/miniBtnPlay"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="▶"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/primary"
                android:textColor="#000000"
                app:cornerRadius="20dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp"/>

            <!-- Skip next -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/miniBtnNext"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="⏭"
                android:textSize="18sp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/text"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"/>

        </LinearLayout>

        <!-- Progress line under mini player -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/miniProgress"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:max="100"
            android:progress="0"
            app:trackColor="#333333"
            app:indicatorColor="@color/primary"/>
    </LinearLayout>

    <!-- Bottom navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#121212"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconSize="20dp"
        app:itemTextAppearanceActive="@style/NavTextActive"
        app:itemTextAppearanceInactive="@style/NavTextInactive"
        app:elevation="0dp"/>

</LinearLayout>
