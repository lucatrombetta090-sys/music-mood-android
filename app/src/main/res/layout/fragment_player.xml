<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- No song state -->
    <TextView
        android:id="@+id/tvNoSong"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="Nessun brano selezionato

Vai in Libreria e tocca un brano"
        android:textColor="@color/subtext"
        android:textSize="15sp"
        android:gravity="center"
        android:lineSpacingExtra="8dp"
        android:visibility="visible"/>

    <!-- Player content -->
    <LinearLayout
        android:id="@+id/playerContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Album art GRANDE - come Spotify -->
        <FrameLayout
            android:id="@+id/artworkBg"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="0dp">

            <ImageView
                android:id="@+id/ivArtwork"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/elevated"
                android:visibility="invisible"/>

            <TextView
                android:id="@+id/tvArtworkLetter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="96sp"
                android:textStyle="bold"
                android:textColor="#535353"
                android:background="@color/elevated"
                android:text="♪"/>
        </FrameLayout>

        <!-- Info + controlli -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp" android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <!-- Titolo + artista + mood pill -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvPlayerTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tvPlayerArtist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/subtext"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Mood pill Spotify-style -->
                <TextView
                    android:id="@+id/tvPlayerMood"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:paddingTop="4dp" android:paddingBottom="4dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:background="@drawable/mood_pill_bg"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Genre + BPM small -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvPlayerGenre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/subtext"
                    android:text="—"/>

                <TextView
                    android:id="@+id/tvPlayerTempo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/subtext"
                    android:layout_marginStart="12dp"
                    android:text=""/>
            </LinearLayout>

            <!-- Seek bar stile Spotify (sottile) -->
            <com.google.android.material.slider.Slider
                android:id="@+id/seekSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:valueFrom="0"
                android:valueTo="1"
                android:value="0"
                app:trackColorActive="@color/text"
                app:trackColorInactive="#535353"
                app:thumbColor="@color/text"
                app:thumbRadius="6dp"
                app:trackHeight="4dp"
                app:labelBehavior="gone"
                app:haloRadius="14dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="-6dp">
                <TextView android:id="@+id/tvTime"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="11sp"
                    android:textColor="@color/subtext" android:text="0:00"/>
                <TextView android:id="@+id/tvDuration"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="@color/subtext" android:text="0:00"/>
            </LinearLayout>

            <!-- Controlli principali Spotify layout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShuffle"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="🔀"
                    android:textSize="18sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textColor="@color/subtext"
                    android:alpha="0.4"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPrev"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="⏮"
                    android:textSize="24sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textColor="@color/text"/>

                <!-- Play button circolare verde Spotify -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPlay"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="center"
                        android:text="▶"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/primary"
                        android:textColor="#000000"
                        app:cornerRadius="28dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:paddingStart="0dp" android:paddingEnd="0dp"/>
                </FrameLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNext"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="⏭"
                    android:textSize="24sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textColor="@color/text"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLoop"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="🔁"
                    android:textSize="18sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textColor="@color/subtext"
                    android:alpha="0.4"/>
            </LinearLayout>

            <!-- Volume slider sottile -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <TextView android:text="🔈"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="14sp" android:textColor="@color/subtext"/>

                <com.google.android.material.slider.Slider
                    android:id="@+id/volSlider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:valueFrom="0"
                    android:valueTo="100"
                    android:value="80"
                    app:trackColorActive="@color/subtext"
                    app:trackColorInactive="#535353"
                    app:thumbColor="@color/subtext"
                    app:thumbRadius="5dp"
                    app:trackHeight="3dp"
                    app:labelBehavior="gone"/>

                <TextView android:text="🔊"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="14sp" android:textColor="@color/subtext"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>
