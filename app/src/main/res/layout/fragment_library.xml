<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="La tua musica"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text"
            android:letterSpacing="-0.02"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilter"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Filtri"
            android:textSize="12sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:backgroundTint="#282828"
            android:textColor="@color/text"
            app:strokeColor="#444444"
            app:strokeWidth="1dp"
            app:cornerRadius="18dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScan"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Scansiona"
            android:textSize="12sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:backgroundTint="@color/primary"
            android:textColor="#000000"
            android:textStyle="bold"
            app:cornerRadius="18dp"/>
    </LinearLayout>

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:orientation="horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="10dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="@drawable/search_bg"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Cerca artisti, brani…"
            android:textSize="14sp"
            android:textColor="@color/text"
            android:textColorHint="@color/subtext"
            android:background="@null"
            android:inputType="text"
            android:imeOptions="actionSearch"/>
    </LinearLayout>

    <!-- Mood chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="4dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipMoodRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"/>
    </HorizontalScrollView>

    <!-- Progress -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressScan"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:visibility="gone"
        app:trackColor="#282828"
        app:indicatorColor="@color/primary"/>

    <!-- Status + count in one row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="2dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"
            android:textColor="@color/subtext"
            android:text=""/>

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/subtext"
            android:text=""/>
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Nessun brano trovato"
        android:textColor="@color/subtext"
        android:textSize="14sp"
        android:visibility="gone"/>

    <!-- Song list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSongs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"/>

</LinearLayout>
