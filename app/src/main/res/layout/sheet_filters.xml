<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#282828"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="#535353"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Filtra per"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GENERE"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/subtext"
        android:letterSpacing="0.12"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingBottom="8dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp" android:paddingEnd="16dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGenre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="4dp" android:paddingBottom="4dp"/>
    </HorizontalScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ANNO"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/subtext"
        android:letterSpacing="0.12"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp" android:paddingEnd="16dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipYear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="4dp" android:paddingBottom="4dp"/>
    </HorizontalScrollView>

    <!-- Buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResetFilters"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Reset"
            app:backgroundTint="#383838"
            android:textColor="@color/text"
            app:cornerRadius="22dp"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplyFilters"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="2"
            android:text="Applica"
            app:backgroundTint="@color/primary"
            android:textColor="#000000"
            android:textStyle="bold"
            app:cornerRadius="22dp"/>

    </LinearLayout>
</LinearLayout>
